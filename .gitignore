# OS / editor
.DS_Store
.DS_Store?
._*
.vscode/
.idea/
*.swp
*.swo

# Python virtual environments & caches (General patterns for monorepos)
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.pytest_cache/
**/.mypy_cache/
**/.venv/
**/venv/
**/.env

# Scoped Python targets (fallback/explicit)
backend/.venv/
backend/__pycache__/
backend/.pytest_cache/
backend/.env
admin_panel/.venv/
admin_panel/__pycache__/
admin_panel/.env

# Flutter / Dart
**/flutter_app/.dart_tool/
**/flutter_app/.packages
**/flutter_app/build/
!**/flutter_app/build/web/
**/flutter_app/.flutter-plugins
**/flutter_app/.flutter-plugins-dependencies
**/flutter_app/.metadata
**/flutter_app/.env

# Android / iOS / macOS ephemeral build outputs
**/flutter_app/android/.gradle/
**/flutter_app/ios/Pods/
**/flutter_app/macos/Pods/

# Misc
*.log
